<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TransLedger</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TransLedger.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Stepper.css" asp-append-version="true" />
</head>
<body>
    <div class="">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
            <div class="container-fluid">
                <a class="navbar-brand" href="/">
                    <strong>TransLedger</strong>
                </a>
                <button class="navbar-toggler p-1" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" href="/">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" aria-current="page" href="/registration">Registration</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" aria-current="page" href="/accounts">Accounts</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="javascript:void(0);" id="navbarDarkDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                List Of
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="/company-list">Company</a></li>
                                <li><a class="dropdown-item" href="/party-list">Party</a></li>
                                <li><a class="dropdown-item" href="/broker-list">Broker</a></li>
                                <li><a class="dropdown-item" href="/vehicle-list">Vehicle</a></li>
                                <li><a class="dropdown-item" href="/driver-list">Driver</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" aria-current="page" href="/transactions">Transactions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" aria-current="page" href="/ledger">Ledger</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" aria-current="page" href="#">Reports</a>
                        </li>
                    </ul>
                    <form method="post" action="/auth/logout">
                        @Html.AntiForgeryToken()

                        <button type="submit"
                                class="btn btn-sm btn-outline-danger">
                            Logout
                        </button>
                    </form>
                </div>
            </div>
        </nav>

        <main class="p-4 p-md-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/Stepper.js" asp-append-version="true"></script>

    <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

    <script>
        $(document).ready(function () {
            $('.data-table').DataTable({
                responsive: true,
                pageLength: 10,
                ordering: true
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
