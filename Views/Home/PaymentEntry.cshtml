@model TransLedger.Models.PaymentEntryViewModel
@{
    string alertType = TempData["AlertType"]?.ToString() ?? "";
    string alertMsg = TempData["AlertMsg"]?.ToString() ?? "";
    var tripNumbers = @Html.Raw(Json.Serialize(ViewBag.TripNumber));
    var AccountNumbers = @Html.Raw(Json.Serialize(ViewBag.AccountNumbers));
}

<div class="d-flex flex-column flex-md-row justify-content-md-between mb-5">
    <div>
        <h2>
            <strong>Payment Entry</strong>
        </h2>
        <p class="text-muted">Record a payment transaction</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(alertMsg))
{
    <div class="alert alert-@alertType">@alertMsg</div>
}

<form method="post">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="mb-4">
                <h4>
                    <strong>Payment Details</strong>
                </h4>
                <p class="text-muted">Enter the details of the payment</p>
            </div>

            <div class="row">

                <div class="col-12 mb-3 d-flex gap-4">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="PaymentType" value="RECEIPT" id="receipt" checked>
                        <label class="form-check-label" for="receipt">
                            <span class="text-success"><i class="bi bi-currency-rupee"></i></span> Receipt (Cr)
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="PaymentType" value="PAYMENT" id="payment">
                        <label class="form-check-label" for="payment">
                            <span class="text-danger"><i class="bi bi-credit-card-2-back"></i></span> Payment (Dr)
                        </label>
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Trip Number</label><span class="text-danger">*</span>
                    <select class="form-control" id="uxTripNumber" asp-for="tripNumber" required>
                        <option value="">-- Select Trip Number --</option>
                        @if (ViewBag.TripNumber != null)
                        {
                            @foreach (var item in (List<TripDetails>)ViewBag.TripNumber)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>

                @* <div class="col-md-6 mb-3">
                    <label class="form-label">Entity Type</label>
                    <select class="form-control" id="entityType" required>
                        <option value="">Select Entity Type</option>
                        <option value="COMPANY">Company</option>
                        <option value="PARTY">Party</option>
                        <option value="BROKER">Broker</option>
                        <option value="VEHICLE">Vehicle</option>
                        <option value="DRIVER">Driver</option>
                    </select>
                </div> *@

             @*    <div class="col-md-6 mb-3">
                    <label class="form-label">Entity</label>
                    <select class="form-control" id="entity" asp-for="EntityAccountId" disabled required>
                        <option value="">Select Entity</option>
                    </select>
                </div> *@
                <input type="hidden" asp-for="HiddenTripid" id="TripId"/>
                
                <div class="col-md-6 mb-3">
                    <label class="form-label">Credited From</label><span class="text-danger">*</span>
                    <input type="text" class="form-control" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" autocomplete="new-password" id="uxcreditedfrom" maxlength="50" disabled />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Mode of Payment</label><span class="text-danger">*</span>
                    <select class="form-control" id="paymentMode" asp-for="ModeOfPayment" required>
                        <option value="">Select Payment Mode</option>
                        <option value="CASH">Cash</option>
                        <option value="UPI">UPI</option>
                        <option value="TRANSFER">Bank Transfer</option>
                        <option value="CHEQUE">Cheque</option>
                        <option value="OTHER">Other</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Credited To</label><span class="text-danger">*</span>
                    <select class="form-control" asp-for="Credited_Accountid" id="uxTripNumber" required>
                        <option value="">-- Select Credited Account --</option>
                        @if (ViewBag.AccountNumbers != null)
                        {
                            @foreach (var item in (List<TripDetails>)ViewBag.AccountNumbers)
                            {
                                <option value="@item.Value">@item.Text - @item.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Amount (₹)</label><span class="text-danger">*</span>
                    <input class="form-control" maxlength="9" onkeypress="return (event.charCode >= 48 && event.charCode <= 57);" placeholder="0.00" asp-for="Amount" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Date</label><span class="text-danger">*</span>
                    <input class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" max="@DateTime.Now.ToString("yyyy-MM-dd")" asp-for="Date" required />
                </div>

                

                <div class="col-md-6 mb-3">
                    <label class="form-label">UTR/TRANSACTION/REFERENCE Number</label><span class="text-danger">*</span>
                    <input class="form-control" maxlength="20" placeholder="UTR/TRANSACTION/REFERENCE Number" id="refNo" asp-for="ReferenceNumber" required />
                </div>
                <div class="col-md-6 mb-3 d-none" id="uxOtherPaymentMethod">
                    <label class="form-label">Other Payment Method</label><span class="text-danger">*</span>
                    <input class="form-control" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" maxlength="20" placeholder="Other Payment Method" id="refNo" asp-for="OtherPaymentMethod" required />
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Remarks</label><span class="text-danger">*</span>
                    <textarea class="form-control" maxlength="200" rows="3" placeholder="Enter Remarks" asp-for="Remarks" required></textarea>
                </div>
            </div>

            <div class="text-end mt-3">
                <button type="reset" class="btn btn-outline-dark" onclick="location.reload()">Cancel</button>
                <button type="submit" class="btn btn-dark">Submit</button>
            </div>
        </div>
    </div>
</form>
<script>
    var tripNumbers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.TripNumber));
</script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $('#uxTripNumber').on('change',function(){
            var selectedId = $(this).val();
            var selectedItem = tripNumbers.find(x => x.Value == selectedId);
            $('#TripId').val(selectedId)
            if (selectedItem) {
               $('#Amount').val(selectedItem.Amount);
               $('#uxcreditedfrom').val(selectedItem.Name);
            } 
            else {
                $('#Amount').val('');
                $('#uxcreditedfrom').val('');
            }
        });

        $('#entityType').on('change', function () {
            let entityType = $('#entityType').val();
            if (entityType) {
                $('#entity').prop('disabled', true);

                $.ajax({
                    url: '/getentitylist/' + entityType,
                    type: 'GET',
                    success: function (response) {
                        let options = '<option value="">Select Entity</option>';

                        response.forEach(item => {
                            options += `<option value="${item.entityAccountId}">${item.entityAccount}</option>`;
                        });

                        $('#entity').html(options).prop('disabled', false);
                    },
                    error: function () {
                        $('#entity')
                            .html('<option value="">No entity present</option>')
                            .prop('disabled', false);
                    }
                });

            } else {
                $('#entity')
                    .html('<option value="">Select Entity</option>')
                    .prop('disabled', true);
            }
        });

        $('#paymentMode').on('change', function () {
            if ($('#paymentMode').val() == 'UPI' || $('#paymentMode').val() == 'TRANSFER' ||
                $('#paymentMode').val() == 'CHEQUE' || $('#paymentMode').val() == 'UPI' ||
                $('#paymentMode').val() == 'OTHER') {

                $('#refNo').prop('disabled', false).prop('required', true).val('');

                if ($('#paymentMode').val() == 'OTHER') {
                    $('#uxOtherPaymentMethod').removeClass('d-none');
                } else {
                    $('#uxOtherPaymentMethod').addClass('d-none');
                }
            }
            else {
                $('#refNo').prop('disabled', true).prop('required', false).val('');
            }
        });
    </script>
}