@{
    string alertType = TempData["AlertType"]?.ToString() ?? "";
    string alertMsg = TempData["AlertMsg"]?.ToString() ?? "";
}

<div class="d-flex flex-column flex-md-row justify-content-md-between mb-5">
    <div>
        <h2>
            <strong>Transactions</strong>
        </h2>
        @* <p class="text-muted">Record a payment transaction</p> *@
    </div>
    <div class="text-md-end mt-3 mt-md-0">
        <button type="button" class="btn btn-dark">
            <i class="bi bi-plus-lg"></i> New Transaction
        </button>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(alertMsg))
{
    <div class="alert alert-@alertType">@alertMsg</div>
}

<div class="card shadow-sm border-0 mb-5">
    <div class="card-body p-4">
        <div class="mb-4">
            <h4>
                <strong>New Transaction</strong>
            </h4>
            <p class="text-muted">Enter the details for the new transaction</p>
        </div>

        <form action="" method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Date</label>
                    <input class="form-control" type="date" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Amount</label>
                    <input class="form-control" placeholder="0.00" />
                </div>

                <div class="col-12 mb-3">
                    <label class="form-label">Description</label>
                    <input class="form-control" placeholder="Transaction Description" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Account Type</label>
                    <select class="form-control">
                        <option value="">Select Account Type</option>
                        <option value="ASSET">Asset</option>
                        <option value="LIABILITY">Liability</option>
                        <option value="INCOME">Income</option>
                        <option value="EXPENSE">Expense</option>
                        <option value="EQUITY">Equity</option>
                    </select>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label class="form-label">Account</label>
                    <select class="form-control">
                        <option value="">Select Account</option>
                    </select>
                </div>
            </div>

            <div class="text-end mt-3">
                <button type="reset" class="btn btn-outline-dark">Cancel</button>
                <button type="submit" class="btn btn-dark">Add Transaction</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle">

            <thead>
                <tr>
                    <th width="60"></th>
                    <th>Date</th>
                    <th>Description</th>
                    <th>Account Type</th>
                    <th>Account</th>
                    <th>Amount</th> @* cr (in green)/dr (in red) *@
                    <th width="140">Action</th>
                </tr>
            </thead>

            <tbody></tbody>

        </table>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}