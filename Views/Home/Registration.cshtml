<div class="d-flex flex-column flex-md-row justify-content-md-between mb-5">
    <div>
        <h2>
            <strong>Registration</strong>
        </h2>
        <p class="text-muted">Register entities involved in your transport business</p>
    </div>
</div>

<div class="row">
    <div class="col-md-6 col-lg-4">
        <div class="card border p-4 mb-4">
            <div class="d-flex gap-3">
                <div class="fs-2 fw-bold"><i class="bi bi-buildings"></i></div>
                <div>
                    <h4><b>Company Registration</b></h4>
                    <p class="text-muted">Register your company details</p>
                </div>
            </div>
            <p class="text-muted py-3">Register company details with GSTIN verification, Aadhar + PAN verification via Digilocker API, and contact information.</p>
            <a class="btn btn-dark full-width" href="/registration/company">Register Company</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border p-4 mb-4">
            <div class="d-flex gap-3">
                <div class="fs-2 fw-bold"><i class="bi bi-people"></i></div>
                <div>
                    <h4><b>Party Registration</b></h4>
                    <p class="text-muted">Register clients and booking parties</p>
                </div>
            </div>
            <p class="text-muted py-3">Register booking parties or clients with GSTIN verification, Aadhar verification, and contact information.</p>
            <a class="btn btn-dark full-width" href="/registration/party">Register Party</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border p-4 mb-4">
            <div class="d-flex gap-3">
                <div class="fs-2 fw-bold"><i class="bi bi-file-earmark-text"></i></div>
                <div>
                    <h4><b>Broker Registration</b></h4>
                    <p class="text-muted">Register brokers and agents</p>
                </div>
            </div>
            <p class="text-muted py-3">Register brokers with Gumasta License verification, Aadhar verification, and commission percentage details.</p>
            <a class="btn btn-dark full-width" href="/registration/broker">Register Broker</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border p-4 mb-4">
            <div class="d-flex gap-3">
                <div class="fs-2 fw-bold"><i class="bi bi-truck"></i></div>
                <div>
                    <h4><b>Vehicle Registration</b></h4>
                    <p class="text-muted">Register vehicles and their details</p>
                </div>
            </div>
            <p class="text-muted py-3">Register vehicles with vehicle number, owner details (Aadhar + PAN), type, capacity, and permit information.</p>
            <a class="btn btn-dark full-width" href="/registration/vehicle">Register Vehicle</a>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card border p-4 mb-4">
            <div class="d-flex gap-3">
                <div class="fs-2 fw-bold"><i class="bi bi-person"></i></div>
                <div>
                    <h4><b>Driver Registration</b></h4>
                    <p class="text-muted">Register drivers and their details</p>
                </div>
            </div>
            <p class="text-muted py-3">Register drivers with name, license number, Aadhar verification, and assigned vehicles.</p>
            <a class="btn btn-dark full-width" href="/registration/driver">Register Driver</a>
        </div>
    </div>
</div>