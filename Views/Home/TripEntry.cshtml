@using System.Data
@using Newtonsoft.Json
@model TransLedger.Models.TripEntryModel
@{
    string alertType = TempData["AlertType"]?.ToString() ?? "";
    string alertMsg = TempData["AlertMsg"]?.ToString() ?? "";
    
    DataTable VEHICLEList = ViewBag.VEHICLEList ?? new DataTable();
    DataTable PARTYList = ViewBag.PARTYList ?? new DataTable();
    DataTable BROKERList = ViewBag.BROKERList ?? new DataTable();
    DataTable DriverList =  ViewBag.DriverList ?? new DataTable();

    string brokerJson = "[]";
    if (BROKERList.Rows.Count > 0)
    {
        brokerJson = JsonConvert.SerializeObject(
            BROKERList.AsEnumerable().Select(row => new
            {
                EntityAccountId = row["EntityAccountId"],
                CommissionPercent = row["CommissionPercent"],
                Name = row["Name"]
            })
        );
    }
}



<div class="d-flex flex-column flex-md-row justify-content-md-between mb-5">
    <div>
        <h2>
            <strong>Trip Entry</strong>
        </h2>
        <p class="text-muted">Create a new trip transaction</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(alertMsg))
{
    <div class="alert alert-@alertType">@alertMsg</div>
}

<form method="post">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="mb-4">
                <h4>
                    <strong>Trip Details</strong>
                </h4>
                <p class="text-muted">Enter the details of the trip</p>
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label class="form-label">LR/Bilty Number</label>
                    <input type="text" class="form-control" max="20" asp-for="LRBiltyNumber" maxlength="100" required placeholder="Enter LR/Bilty Number" onpaste="return false;" />
                </div>

                @*<div class="col-md-6 mb-3">
                    <label class="form-label">LR Number</label>
                    <input type="text" class="form-control" maxlength="10" asp-for="LRNumber" onpaste="return false;" onkeypress="return (event.charCode >= 48 && event.charCode <= 57);" required placeholder="Enter LR Number" />
                </div> *@

                <div class="col-md-4 mb-3">
                    <label class="form-label">Vehicle Number</label>
                    <select class="form-control" asp-for="VehicleNumber" id="uxVehical" value="EntityAccountId"  required>
                        <option value="">Select Vehicle Number</option>
                        @foreach (DataRow row in VEHICLEList.Rows)
                        {
                             <option value="@row["EntityAccountId"]">@row["VehicleNumber"]</option>
                        }
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Vehical Weights</label>
                    <input type="text" class="form-control" id="VehicalWeights" placeholder="Enter LR/Bilty Number" readonly />
                </div>
            </div>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label class="form-label">Vehicle Owner Name.</label>
                    <input type="text" class="form-control" id="VehicleOwner" max="20" maxlength="100" placeholder="Vehicle Owner Name." readonly />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Vehicle Owner Mobile No.</label>
                    <input type="text" class="form-control" id="VehicleMobileName" max="20" maxlength="100" placeholder="Vehicle Mobile No." readonly/>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Date</label>
                    <input class="form-control" asp-for="Date" 
                    value="@DateTime.Now.ToString("yyyy-MM-dd")"  type="date" required />
                </div>
            </div>
            <div class="row">

                <div class="col-md-4 mb-3">
                    <label class="form-label">Hiring Amount For the owner (₹)</label>
                    <input type="text" class="form-control" asp-for="HiringAmountForowner" maxlength="9" onpaste="return false;" onkeypress="return (event.charCode >= 48 && event.charCode <= 57);" placeholder="Enter amount (e.g. 1,250.50)" pattern="^\d{1,3}(,\d{3})*(\.\d{2})?$" required />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Broker (if applicable)</label>
                    <select class="form-control" asp-for="BrokerId" id="uxBrocker" required>
                        <option value="">Select Broker</option>
                        @foreach (DataRow row in BROKERList.Rows)
                        {
                            <option value="@row["EntityAccountId"]">@row["Name"]</option>
                        }
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Hiring Amount For Broker (₹)</label>
                    <input type="text" class="form-control" asp-for="HiringAmountForBroker" maxlength="9" onpaste="return false;" onkeypress="return (event.charCode >= 48 && event.charCode <= 57);" placeholder="Enter amount (e.g. 1,250.50)" pattern="^\d{1,3}(,\d{3})*(\.\d{2})?$" required />
                </div>
            </div>

             @*    <div class="col-md-6 mb-3">
                    <label class="form-label">LR Number</label>
                    <input type="text" class="form-control" maxlength="10" asp-for="LRNumber" onpaste="return false;" onkeypress="return (event.charCode >= 48 && event.charCode <= 57);" required placeholder="Enter LR Number" />
                </div> *@
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Booking Party</label>
                    <select class="form-control" id="uxBookingParty" asp-for="BookingPartyId" required>
                        <option value="">Select Booking Party</option>
                        @foreach (DataRow row in PARTYList.Rows)
                        {
                             <option value="@row["EntityAccountId"]">@row["Name"]</option>
                        }
                    </select>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Hiring Amount from Party (₹)</label>
                    <input type="text" class="form-control" asp-for="HiringAmountfromParty" maxlength="9" onpaste="return false;" onkeypress="return (event.charCode >= 48 && event.charCode <= 57);" placeholder="Enter amount (e.g. 1,250.50)" pattern="^\d{1,3}(,\d{3})*(\.\d{2})?$" required />
                </div>

               <div class="col-md-4 mb-3">
                    <label class="form-label">Driver</label>
                    <select class="form-control" asp-for="Driver" id="uxDriver" required>
                        <option value="">Select Driver</option>
                        @foreach (DataRow row in DriverList.Rows)
                        {
                            <option value="@row["EntityAccountId"]">@row["Name"]</option>
                        }
                    </select>
               </div>

            </div>
            <div class="row">
                <hr class="mt-3 mb-4" />

              @*   <div class="col-md-4 mb-3">
                    <label class="form-label">Commission/Brokerage (₹)</label>
                    <input type="text"  class="form-control" id="uxcommissionbrockarage" asp-for="CommissionBrokerage" placeholder="Enter amount (e.g. 1,250.50)" onpaste="return false;" pattern="^\d{1,3}(,\d{3})*(\.\d{2})?$" readonly />
                </div> *@

                <div class="col-md-4 mb-3">
                    <label class="form-label">Loading Point</label>
                    <input type="text" class="form-control" asp-for="LoadingPoint" maxlength="100" required placeholder="Enter Loading Point" onpaste="return false;"/>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Unloading Point</label>
                    <input type="text" class="form-control" maxlength="100" asp-for="UnloadingPoint" onpaste="return false;" required placeholder="Enter Unloading Point" />
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Remarks</label>
                    <textarea id="uxremarks" class="form-control" rows="3" asp-for="Remarks" onpaste="return false;" maxlength="250" required placeholder="Enter Remarks"></textarea>
                </div>
            </div>

            <div class="text-end mt-3">
                <button type="reset" class="btn btn-outline-dark">Cancel</button>
                <button type="submit" class="btn btn-dark">Submit</button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var BROKERList = @Html.Raw(brokerJson);
        // ('#entityType').on('change', function () {
        $(document).ready(function () {
            $('#uxBrocker').change(function () {
                var selectedBrokerId = parseInt($(this).val());
                var foundRow = BROKERList.find(function (row) {
                    return parseInt(row.EntityAccountId) === selectedBrokerId;
                });
                if (foundRow) {
                    $('#uxcommissionbrockarage').val(foundRow.CommissionPercent);
                }
            });
        });

        $('#uxVehical').change(function(e) {
            var selectedvehicalid  = parseInt($(this).val())
            $.ajax({
                url:'/Home/getVehicaleDetails',
                type:'POST',
                data:{
                    selectedvehicalid: selectedvehicalid
                },
                success:function(response){
                    console.log(response)
                    if(response.success){
                        $('#VehicalWeights').val(response.vehicalWeights);
                        $('#VehicleOwner').val(response.vehicalOwnerName);
                        $('#VehicleMobileName').val(response.vehicleMobileName);
                    }
                    else
                    {
                        console.log(1)
                        console.log(response)
                        alert(response.message);
                    }
                },
                error:function(xhr, status, error){
                    alert("error : - " + error);
                }
            })
        })

        $('form').submit(function (e) {
           e.preventDefault();
           $.ajax({
               url:'/Home/TripEntry',
               type:'POST',
               data:$(this).serialize(),
               success:function(response){
                   if (response.success) {
                           var today = new Date().toISOString().split('T')[0];
                           $('input[type="date"]').val(today);
                           $('#uxBrocker').val('');
                           $('#uxVehical').val('');
                           $('#uxBookingParty').val('');
                           $('#uxremarks').val('');
                   } 
                   else {
                        alert(response.message);
                   }
               },
               error: function (xhr, status, error) {
                console.log(error);
                alert('Something went wrong');
               }
           })
        });
    </script>
}

